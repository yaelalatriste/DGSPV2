                $("#inputAlmacen").val("");
                $("#inputCantidad").val("");
                $("#inputCantidadPresentacion").val("");
                $("#inputCantidadEnvase").val("");
                $("#inputRestante").val("");
                $("#inputMedicamento").val("");
                $("#inputPresentacionMedicamento").val("");                
                let pasa = await buscarLoteDetalle($(this).val());
                if(pasa == true)
                {
                    Swal.fire({
                        allowOutsideClick: false,
                        icon: "info",
                        title: 'Detalle del Traspaso',
                        html: "Buscando lote de medicamento, espere por favor."
                    });
                    Swal.showLoading();
                    axios.get('/smedicos/medicamentos/' + modulo.id+'/' + submodulo.id+'/notasTraspaso/'+opcion.id+'/detalle/' + notaTraspaso.id+'?lote='+$(this).val() + '&consultorio='+notaTraspaso.consultorioId+'&handler=MedicamentosPorLote').then(response => {
                        if (response.status == 200 && response.data.id != 0) {
                               let medicamentos = response.data;
                               if(medicamentos.length == 1)
                               {
                                   cargarDatosMedicamento(medicamentos[0]);
                                   Swal.close();
                                   return;
                               }
                               console.log(medicamentos);
                               if(medicamentos.length > 1)
                               {
                                   Swal.close();
                                   medicamentosEncontrados = medicamentos;
                                   let html = "";
                                   medicamentos.forEach(m => {
                                       html += `<tr>
                                            <td>${m.medicamento.nombre}</td>
                                            <td>${m.medicamento.presentacion}</td>
                                            <td>${m.formaFarmaceutica.nombre}</td>
                                            <td>${m.tipoEnvase.nombre}</td>
                                            <td>
                                                <button class="btn btn-sm btn-primary seleccionarMedicamento" data-id="${m.id}">
                                                Seleccionar
                                                </button>
                                            </td>
                                        </tr>`;
                                    });
                                    $("#tblMedicamentosLote").html(html);
                                    $("#modalSeleccionMedicamento").modal("show");
                                }
                         }
                    });
                 }
                 else
                 {
                      Swal.fire({
                          allowOutsideClick: false,
                          icon: "info",
                          title: 'Detalle del Traspaso',
                          html: "<p style='text-align: justify'>Verifique que el <b>Lote exista en el consultorio origen</b> o bien, <b>ya existe un registro del medicamento</b> con ese lote dentro de la <b>Nota de Traspaso</b>, si deseas modificarlo has clic en el icono <i class='fas fa-pencil text-primary'></i> para actualizarlo.</p>"
                      }).then(function(){
                          $("#inputLoteMedicamento").val("");
                          return false;
                      });
                 }
            });
            
            $(document).on("click",".seleccionarMedicamento",function () {
                let id = $(this).data("id");
                let medicamento = medicamentosEncontrados.find(x => x.id == id);
                if(medicamento)
                {
                    cargarDatosMedicamento(medicamento);
                    $("#modalSeleccionMedicamento").modal("hide");
