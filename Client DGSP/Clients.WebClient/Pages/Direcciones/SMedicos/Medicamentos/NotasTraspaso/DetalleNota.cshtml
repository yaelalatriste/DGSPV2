            $("#inputCantidad").change(function(){
                let cantidadP = $("#inputCantidadPresentacion").val();
                let cantidadE = $("#inputCantidadEnvase").val();
                let cantidadT = $(this).val();
                let formaFarmaceutica = $("#inputFormaFarmaceutica").val();
                let tipoEnvase = $("#inputTipoEnvase").val();
                let restante = cantidadP-cantidadT;
                let restanteEnvase = restante*cantidadE;
                if(restante < 0)
                {
                    Swal.fire({
                        icon: "error",
                        title: 'Detalle del Traspaso',
                        html: "No hay suficiente medicamento para traspasar, favor de revisar."
                    });
                }
                $("#inputRestanteEnvase").val(restanteEnvase);
                $("#inputRestante").val(restante);
                $("#divRestantePresentacion").html("<p style='text-align: justify;'><b>Restante en presentación:</b> "+restante+" "+(restante == 1 ? tipoEnvase:tipoEnvase+"s")+"</p>");
                $("#divRestanteContenido").html("<p style='text-align: justify;'><b>Restante en contenido: </b> "+restanteEnvase+" "+(restanteEnvase== 1 ? formaFarmaceutica.slice(0,-1): formaFarmaceutica)+"</b></p>");
            });


             function validaDatos()
            {
                let tipoMovimientoId = $("#inputTipoMovimiento").val();
                let loteId = $("#inputLoteId").val();
                let cantidad = $("#inputCantidad").val();
                let restante = $("#inputRestante").val();

                if(loteId != 0 && cantidad != 0){
                    return true;
                }

                if(restante < 0){
                    Swal.fire({
                         icon: 'error',
                         title: 'Detalle de la Nota de Traspaso',
                         html: "No se puede agregar el medicamento a la nota, ya que <b>No hay suficiente en almacén</b>."
                     }).then(function () {
                         return false;
                     });
                }

                if(cantidad == 0 || cantidad == ""){
                    Swal.fire({
                         icon: 'error',
                         title: 'Detalle de la Nota de Traspaso',
                         html: "No ha capturado la <b>Cantidad a destinar</b>."
                     }).then(function () {
                          $("#error_inputDestinoId").css("display","block");
                         return false;
                     });
                }

                if(loteId == 0 || loteId == ""){
                    Swal.fire({
                         icon: 'error',
                         title: 'Detalle de la Nota de Traspaso',
                         html: "No ha capturado el <b>Lote del Medicamento</b>."
                     }).then(function () {
                         $("#error_inputLoteMedicamento").css("display","block");
                         return false;
                     });
                }

                if(tipoMovimientoId == 0 || tipoMovimientoId == ""){
                    Swal.fire({
                         icon: 'error',
                         title: 'Detalle de la Nota de Traspaso',
                         html: "No ha seleccionado el <b>Tipo de Movimiento</b>."
                     }).then(function () {
                         $("#error_inputTipoMovimiento").css("display","block");
                         return false;
                     });
                }
            }

