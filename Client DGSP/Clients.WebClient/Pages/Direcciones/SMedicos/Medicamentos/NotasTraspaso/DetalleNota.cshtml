                let url = '/smedicos/medicamentos/' + modulo.id + '/' + submodulo.id + '/notasTraspaso/' + opcion.id + '/detalle/' + notaTraspaso.id + '?notaId=' + notaTraspaso.id + '&handler=VisualizarEntregable';
