@*Card para la tabla de Sumatorias*@
<div class="row mt-3" id="divCalculosPoliza">
    <div class="row col-lg-12">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header bg-secondary">Cotización</div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>UMA's</th>
                                    <th>Suma Asegurada</th>
                                    <th class="col-titular edad-titular-1">Titular 0-19</th>
                                    <th class="col-titular edad-titular-2">Titular 20-59</th>
                                    <th class="col-titular edad-titular-3">Titular 60-69</th>
                                    <th class="col-titular edad-titular-4">Titular 70-89</th>
                                    <th class="col-conyuge edad-conyuge-1">Cónyuge 0-19</th>
                                    <th class="col-conyuge edad-conyuge-2">Cónyuge 20-59</th>
                                    <th class="col-conyuge edad-conyuge-3">Cónyuge 60-69</th>
                                    <th class="col-conyuge edad-conyuge-4">Cónyuge 70-89</th>
                                    <th class="col-hijo019">Hijo(a) 0-19</th>
                                    <th class="col-hijo2059">Hijo(a) 20-24</th>
                                    <th class="col-hijo25">Hijo(a) &gt; 25 años</th>
                                    <th class="col-asc">Ascendente(s)</th>
                                    <th>Total Póliza</th>
                                    <th>Descuento Quincenal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Poliza != null && Model.Poliza.Any())
                                {
                                    foreach (var item in Model.Poliza)
                                    {
                                        <tr class="fila-poliza" data-poliza="@item.SumaAsegurada" data-nivel="@Model.FiltrosPoliza.Nivel"
                                                data-sumabasica="@Model.Catalogos.SumasBasicas.Where(tp => tp.Id == Model.FiltrosPoliza.SumaBasica).First().Descripcion">
                                                <td>@item.SumaAsegurada</td>
                                                <td>@String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", Model.UMA * Convert.ToDecimal(item.SumaAsegurada))</td>

                                                <td class="monto col-titular edad-titular-1"
                                                    data-tipo="titular"
                                                    data-original="@item.Titular019">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Titular019)
                                                </td>

                                                <td class="monto col-titular edad-titular-2"
                                                    data-tipo="titular"
                                                    data-original="@item.Titular2059">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Titular2059)
                                                </td>

                                                <td class="monto col-titular edad-titular-3"
                                                    data-tipo="titular"
                                                    data-original="@item.Titular6069">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Titular6069)
                                                </td>

                                                <td class="monto col-titular edad-titular-4"
                                                    data-tipo="titular"
                                                    data-original="@item.Titular7089">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Titular7089)
                                                </td>

                                                <td class="monto col-conyuge edad-conyuge-1"
                                                    data-tipo="conyuge"
                                                    data-original="@item.Conyuge019">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Conyuge019)
                                                </td>

                                                <td class="monto col-conyuge edad-conyuge-2"
                                                    data-tipo="conyuge"
                                                    data-original="@item.Conyuge2059">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Conyuge2059)
                                                </td>

                                                <td class="monto col-conyuge edad-conyuge-3"
                                                    data-tipo="conyuge"
                                                    data-original="@item.Conyuge6069">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Conyuge6069)
                                                </td>

                                                <td class="monto col-conyuge edad-conyuge-4"
                                                    data-tipo="conyuge"
                                                    data-original="@item.Conyuge7089">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Conyuge7089)
                                                </td>

                                                <td class="monto col-hijo019"
                                                    data-tipo="hijo019"
                                                    data-original="@item.Hijo019">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Hijo019)
                                                </td>

                                                <td class="monto col-hijo2059"
                                                    data-tipo="hijo2059"
                                                    data-original="@item.Hijo2059">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Hijo2059)
                                                </td>

                                                <td class="monto montoHijo25"
                                                    data-tipo="hijo25"
                                                    data-original="@item.HijoM25">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.HijoM25)
                                                </td>

                                                <td class="monto montoAsc"
                                                    data-tipo="ascendiente"
                                                    data-original="@item.Ascendentes">
                                                    @String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", item.Ascendentes)
                                                </td>
                                                <td class="totalFila font-weight-bold">$0.00</td>
                                                <td class="totalFilaQuincenal font-weight-bold">$0.00</td>
                                            </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center">
                                            No hay información para mostrar.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Modal para los filtros  *@
<div class="modal fade" id="modalFiltros">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <h4 class="modal-title text-white">Filtros SGMM</h4>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <form method="post">
                <div class="modal-body">

                    <div class="card-body">
                        <div class="row">
                            <div class="row col-lg-12">
                                <div class="form-group col-lg-1">
                                    <label>Año:</label>
                                    <input asp-for="FiltrosPoliza.Anio" type="number" class="form-control" readonly value="@DateTime.Now.Year" />
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Tipo de Póliza:</label>
                                    <select asp-for="FiltrosPoliza.TipoPoliza" id="TipoPoliza" class="form-control">
                                        <option value="">Seleccione el tipo de póliza</option>
                                        @foreach (var tp in Model.Catalogos.Vigencias)
                                        {
                                            <option value="@tp.Id">@(tp.Descripcion.Contains("GM") ? "Mando Medio" : "Operativo")</option>
                                        }
                                    </select>
                                </div>

                                <div class="form-group col-lg-4">
                                    <label>Suma Básica:</label>
                                    <select asp-for="FiltrosPoliza.SumaBasica" id="SumaBasica" class="form-control">
                                        <option value="">Seleccione la suma básica</option>
                                        @foreach (var sb in Model.Catalogos.SumasBasicas)
                                        {
                                            <option value="@sb.Id">@sb.Descripcion</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-group col-lg-3">
                                    <label>IQ:</label>
                                    <select asp-for="FiltrosPoliza.IQ" class="form-control" id="Iq">
                                        @foreach (var iq in Model.Catalogos.IQ)
                                        {
                                            <option value="@iq.Id">@iq.Descripcion</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="row col-lg-12">
                                <div class="form-group col-lg-3">
                                    <label>Fecha Inicial:</label>
                                    <input type="date" class="form-control" asp-for="FiltrosPoliza.FechaInicio" />
                                </div>
                                <div class="form-group col-lg-3">
                                    <label>Fecha Final:</label>
                                    <input type="date" class="form-control" asp-for="FiltrosPoliza.FechaFinal" />
                                </div>
                                <div class="form-group col-lg-3">
                                    <label>Quincenas:</label>
                                    <select asp-for="FiltrosPoliza.Quincenas" class="form-control">
                                        <option value="">Seleccione la quincena</option>
                                        @for (int i = quincenaActual + 1; i <= 22; i++)
                                        {
                                            <option value="@i">@i Quincena(s)</option>
                                        }
                                    </select>
                                </div>
                                <div class="form-check-inline i-checks mt-3" id="nivel211">
                                    <strong class="text-black mr-3">¿Es nivel 1 al 11?</strong>
                                    <input class="chkNivel" type="checkbox" data-toggle="toggle"
                                           data-on="<i class='fa fa-check'></i>" data-off="<i class='fa fa-times'></i>"
                                           data-onstyle="success" data-offstyle="danger" asp-For="FiltrosPoliza.Nivel"
                                           data-style="ios">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white">
                    <button type="submit" class="btn btn-primary float-right">
                        Enviar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(function(){
            var modulo = @Html.Raw(Json.Serialize(Model.Modulo));
            var submodulo = @Html.Raw(Json.Serialize(Model.Submodulo));
            var opcion = @Html.Raw(Json.Serialize(Model.Opcion));

            $("#filtrosSGMM").click(function(){
                $("#modalFiltros").modal('show');
            });
            
            function limpiarNivel() 
            {
                $(".chkNivel")
                .prop("checked", false)
                .bootstrapToggle("off");
            }
            
            $("#SumaBasica").on("change", function () {
                if ($(this).val() == 5) {
                    $("#nivel211").show();
                }
                else {
                    $("#nivel211").hide();
                    limpiarNivel();
                }
            });

            $(document).on("click", ".verTablaPoliza", function (e) {
                e.preventDefault();
                $("#divCalculosPoliza").show();
                recalcularTabla();
            });

                   const sumaBasica = document.getElementById("SumaBasica");
        const tipoPoliza = document.getElementById("TipoPoliza");
        const opcionesOriginales = Array.from(sumaBasica.options).map(
            opcion => opcion.cloneNode(true)
        );

        function cargarSumasBasicas(limpiarSeleccion = true) {

            const tipoPolizaId = tipoPoliza.value;
            const sumaSeleccionada = sumaBasica.value;

            sumaBasica.innerHTML = "";

            // Opción inicial
            sumaBasica.appendChild(
                opcionesOriginales[0].cloneNode(true)
            );

            if (tipoPolizaId === "61") {

                // Operativo: solamente la suma básica 111.
                // Actualmente tomas opcionesOriginales[1].
                sumaBasica.appendChild(
                    opcionesOriginales[1].cloneNode(true)
                );
            }
            else if (tipoPolizaId === "60") {

                // Mando Medio: mostrar todas las sumas.
                for (let i = 1; i < opcionesOriginales.length; i++) {
                    sumaBasica.appendChild(
                        opcionesOriginales[i].cloneNode(true)
                    );
                }
            }

            if (limpiarSeleccion) {
                sumaBasica.value = "";
                limpiarNivel();
                $("#nivel211").hide();
            }
            else {
                /*
                 * Al recargar después de enviar los filtros,
                 * intenta conservar la suma básica seleccionada.
                 */
                const existeSeleccion = Array.from(sumaBasica.options)
                    .some(opcion => opcion.value === sumaSeleccionada);

                sumaBasica.value = existeSeleccion
                    ? sumaSeleccionada
                    : "";
            }

            // Actualizar la visibilidad del check de nivel.
            $("#SumaBasica").trigger("change");
        }

        tipoPoliza.addEventListener("change", function () {
            cargarSumasBasicas(true);
        });

        // Ejecutar también al cargar la página.
        cargarSumasBasicas(false);

            $(document).on("click", ".btn-plus", function () {
                var input = $(this).closest(".input-group").find(".cantidad");
                var valor = parseInt(input.val() || 0);

                // Cónyuge solo puede ser 1
                if (input.attr("id") === "conyuge" && valor >= 1) {
                    return;
                }

                input.val(valor+1);
                recalcularTabla();
            });

            $(document).on("click", ".btn-minus", function () {
                var input = $(this).closest(".input-group").find(".cantidad");
                var valor = parseInt(input.val() || 0);

                if (valor > 0) {
                    input.val(valor - 1);
                }
                recalcularTabla();
            });

            $(document).on("change", ".rango-edad, .aplica", function () {
                recalcularTabla();
            });

            function money(valor) {
                return valor.toLocaleString('es-MX', {
                    style: 'currency',
                    currency: 'MXN'
                });
            }

            function obtenerCantidad(tipo) {
                return parseInt($("#" + tipo).val()) || 0;
            }

            function recalcularTabla() {

                var edadTitular = $("#edadTitular").val();
                var edadConyuge = $("#edadConyuge").val();

                var titular = obtenerCantidad("titular");
                var conyuge = obtenerCantidad("conyuge");
                var hijo019 = obtenerCantidad("hijo019");
                var hijo2059 = obtenerCantidad("hijo2059");
                var hijo25 = obtenerCantidad("hijo25");
                var ascendiente = obtenerCantidad("ascendiente");

                var aplicaHijo25 = parseInt($("#aplicaHijo25").val()) || 0;
                var aplicaAsc = parseInt($("#aplicaAscendiente").val()) || 0;

                /*
                 * Ocultar inicialmente las columnas dependientes
                 * de las cantidades y rangos seleccionados.
                 */
                $(".col-titular").hide();
                $(".col-conyuge").hide();
                $(".col-hijo019").hide();
                $(".col-hijo2059").hide();

                if (titular > 0 && edadTitular !== "0") {
                    $(".edad-titular-" + edadTitular).show();
                }

                if (conyuge > 0 && edadConyuge !== "0") {
                    $(".edad-conyuge-" + edadConyuge).show();
                }

                if (hijo019 > 0) {
                    $(".col-hijo019").show();
                }

                if (hijo2059 > 0) {
                    $(".col-hijo2059").show();
                }

                /*
                 * Mostrar u ocultar la columna de hijo mayor de 25 años.
                 */
                if (hijo25 > 0) {
                    $(".montoHijo25").show();

                    $("th").filter(function () {
                        return $(this).text().trim() === "Hijo(a) > 25 años";
                    }).show();
                } else {
                    $(".montoHijo25").hide();
                    $("th").filter(function () {
                        return $(this).text().trim() === "Hijo(a) > 25 años";
                    }).hide();
                }

                /*
                 * Mostrar u ocultar la columna de ascendientes.
                 */
                if (ascendiente > 0) {
                    $(".montoAsc").show();
                    $("th").filter(function () {
                        return $(this).text().trim() === "Ascendente(s)";
                    }).show();
                } else {
                    $(".montoAsc").hide();
                    $("th").filter(function () {
                        return $(this).text().trim() === "Ascendente(s)";
                    }).hide();
                }

                /*
                 * Obtener valores adicionales de la póliza 0.
                 */
                var filaPolizaCero = $(".fila-poliza[data-poliza='0']");

                var extraHijo25 = 0;
                var extraAsc = 0;

                if (filaPolizaCero.length > 0) {

                    extraHijo25 =
                        parseFloat(
                            filaPolizaCero
                                .find(".montoHijo25")
                                .attr("data-original")
                        ) || 0;
                        
                        extraAsc = parseFloat(filaPolizaCero
                            .find(".montoAsc")
                            .attr("data-original")
                        ) || 0;
                }
                /*
                * Obtener los montos originales de la fila 111 UMA.
                */
               var filaNivel111 = $(".fila-poliza[data-poliza='111']").first();

                var montosNivel111 = {
                    titular019: obtenerMontoOriginal(filaNivel111.find(".edad-titular-1")),
                    titular2059: obtenerMontoOriginal(filaNivel111.find(".edad-titular-2")),
                    titular6069: obtenerMontoOriginal(filaNivel111.find(".edad-titular-3")),
                    titular7089: obtenerMontoOriginal(filaNivel111.find(".edad-titular-4")),
                    conyuge019: obtenerMontoOriginal(filaNivel111.find(".edad-conyuge-1")),
                    conyuge2059: obtenerMontoOriginal(filaNivel111.find(".edad-conyuge-2")),
                    conyuge6069: obtenerMontoOriginal(filaNivel111.find(".edad-conyuge-3")),
                    conyuge7089: obtenerMontoOriginal(filaNivel111.find(".edad-conyuge-4")),
                    hijo019: obtenerMontoOriginal(filaNivel111.find(".col-hijo019")),
                    hijo2059: obtenerMontoOriginal(filaNivel111.find(".col-hijo2059"))
                };

                /*
                 * Recorrer cada fila de la tabla.
                 */
                $(".fila-poliza").each(function () {
                    var filaActual = $(this);
                    filaActual.show();
                    var totalFila = 0;
                    var sumaBasicaValue = $(this).data("sumabasica");
                    var poliza = parseInt(filaActual.attr("data-poliza")) || 0;
                    var esPolizaCero = poliza === 0;
                    
                    var nivelMMValor = String(filaActual.attr("data-nivel") || "").toLowerCase();
                    var nivelMM = nivelMMValor === "true" || nivelMMValor === "1";
                    
                    filaActual.find(".monto").each(function () {
                        var celda = $(this);
                        var tipo = celda.attr("data-tipo");
                        var original = parseFloat(celda.attr("data-original")) || 0;
                        var montoBase = original;
                        var total = 0;
                        /*
                         * Nuevo requerimiento:
                         *
                         * Cuando Nivel sea true, se suma el monto de la fila 111
                         * al monto original de cada fila.
                         *
                         * Solo aplica para:
                         * - Titular
                         * - Cónyuge
                         * - Hijos menores de 25 años
                         *
                         * La fila 111 no se suma consigo misma.
                         */
                        if (nivelMM && poliza !== 111 && !esPolizaCero) {
                            if (tipo === "titular" &&celda.hasClass("edad-titular-1")) 
                            {
                                montoBase = original + montosNivel111.titular019;
                            }
                            
                            if (tipo === "titular" && celda.hasClass("edad-titular-2")) 
                            {
                                montoBase = original + montosNivel111.titular2059;
                            }
                            
                            if (tipo === "titular" && celda.hasClass("edad-titular-3")) 
                            {
                                montoBase = original + montosNivel111.titular6069;
                            }
                            
                            if (tipo === "titular" && celda.hasClass("edad-titular-4")) 
                            {
                                montoBase = original + montosNivel111.titular7089;
                            }
                            
                            if (tipo === "conyuge" && celda.hasClass("edad-conyuge-1")) 
                            {
                                montoBase = original + montosNivel111.conyuge019;
                            }
                            
                            if (tipo === "conyuge" && celda.hasClass("edad-conyuge-2")) 
                            {
                                montoBase = original + montosNivel111.conyuge2059;
                            }
                            
                            if (tipo === "conyuge" && celda.hasClass("edad-conyuge-3")) 
                            {
                                montoBase = original + montosNivel111.conyuge6069;
                            }

                            if (tipo === "conyuge" && celda.hasClass("edad-conyuge-4")) 
                            {
                                montoBase = original + montosNivel111.conyuge7089;
                            }
                            
                            if (tipo === "hijo019") 
                            { 
                                montoBase = original + montosNivel111.hijo019;
                            }
                            
                            if (tipo === "hijo2059") 
                            {
                                montoBase = original + montosNivel111.hijo2059;
                            }
                       }

                        /*
                         * Aplicar cantidades por tipo de persona.
                         */
                        if (tipo === "titular") {
                            total = (nivelMM && poliza !== 111 && poliza !== 148 ? montoBase * titular : poliza <= sumaBasicaValue ? 0 : montoBase);
                        }

                        if (tipo === "conyuge") {
                            total = (nivelMM && poliza !== 111 && poliza !== 148 ? montoBase * conyuge : poliza <= sumaBasicaValue ? 0 : montoBase);
                        }

                        if (tipo === "hijo019") {
                            total = (nivelMM && poliza !== 111 && poliza !== 148 ? montoBase * hijo019 : poliza <= sumaBasicaValue ? 0 : montoBase);
                        }

                        if (tipo === "hijo2059") {
                            total = (nivelMM && poliza !== 111 && poliza !== 148 ? montoBase * hijo2059 : poliza <= sumaBasicaValue ? 0 : montoBase);
                        }

                         /*
                         * Hijo mayor de 25:
                         * no se le suma la fila 111.
                         */
                        if (tipo === "hijo25") {
                            
                            total = original * hijo25;
                            
                            if (aplicaHijo25 === 1 &&!esPolizaCero) 
                            {
                                total += extraHijo25 * hijo25;
                            }

                            if (aplicaHijo25 === 0) {
                                total = original * hijo25;
                            }
                        }

                        /*
                         * Ascendientes:
                         * no se les suma la fila 111.
                         */
                        if (tipo === "ascendiente") 
                        {
                            total = original * ascendiente;
                        
                            if (aplicaAsc === 1 && !esPolizaCero) 
                            {
                                total += extraAsc * ascendiente;
                            }
                            
                            if (aplicaAsc === 0) 
                            {
                                total = original * ascendiente;
                            }
                        }
                        
                        celda.text(money(total));
                        
                        if ( celda.is(":visible") && !esPolizaCero) 
                        {
                            totalFila += total;
                        }
                   });
                   
                   filaActual.find(".totalFila").text(money(totalFila));
                   
                   var quincenas = parseInt("@Model.FiltrosPoliza.Quincenas") || 1;
                   
                   filaActual.find(".totalFilaQuincenal").text(money(totalFila / quincenas));
                   
                   if (Math.abs(totalFila) < 0.01) {
                       filaActual.hide();
                   } else {
                       filaActual.show();
                   }
                });

                /*
                 * La póliza 0 se utiliza únicamente para obtener adicionales.
                 */

                filaPolizaCero.hide();
            }
            
            function obtenerMontoOriginal(elemento) 
            {
                if (!elemento || elemento.length === 0) 
                {
                    return 0;
                }
                return parseFloat(elemento.first().attr("data-original")) || 0;
            }

            @if (Model.Poliza != null && Model.Poliza.Any() && Model.FiltrosPoliza.SumaBasica != 0)
            {
                    <text>
                        $("#divCalculosPoliza").show();
                        recalcularTabla();
                    </text>
            }
            else
            {
                    <text>
                        $("#divCalculosPoliza").hide();
                    </text>
            }
            
            function obtenerDecimal(valor) {
                if (valor === null || valor === undefined) {
                    return 0;
                }
                const numero = String(valor).replace(/\$/g, "").replace(/,/g, "").trim();
                return parseFloat(numero) || 0;
            }
            
            function obtenerMontoTitular(fila) {
                return obtenerDecimal(fila.find(".col-titular:visible").text());
            }
            
            function obtenerMontoConyuge(fila) {
                return obtenerDecimal(fila.find(".col-conyuge:visible").text());
            }
            
            function obtenerMontoHijo019(fila) {
                return obtenerDecimal(fila.find(".col-hijo019").text());
            }
            
            function obtenerMontoHijo2059(fila) {
                return obtenerDecimal(fila.find(".col-hijo2059").text());
            }

            $(".enviarCorreo").click(function(){
                const datosFiltros = 
                {
                    anio: parseInt("@Model.FiltrosPoliza.Anio") || 0,
                    tipoPoliza: parseInt("@Model.FiltrosPoliza.TipoPoliza") || 0,
                    sumaBasica: parseInt("@Model.FiltrosPoliza.SumaBasica") || 0,
                    iq: parseInt("@Model.FiltrosPoliza.IQ") || 0,
                    fechaInicio: "@Model.FiltrosPoliza.FechaInicio.ToString("yyyy-MM-dd")",
                    fechaFinal: "@Model.FiltrosPoliza.FechaFinal.ToString("yyyy-MM-dd")",
                    quincenas: parseInt("@Model.FiltrosPoliza.Quincenas") || 0,
                    nivel: String("@Model.FiltrosPoliza.Nivel").toLowerCase() === "true",
                };

                const datosCotizacion = {
                    filtros: datosFiltros,
                    edadTitular: $("#edadTitular option:selected").text() || "",
                    cantidadTitular: obtenerCantidad("titular"),
                    edadConyuge: $("#edadConyuge option:selected").text() || "",
                    cantidadConyuge: obtenerCantidad("conyuge"),
                    cantidadHijo019: obtenerCantidad("hijo019"),
                    cantidadHijo2024: obtenerCantidad("hijo2059"),
                    cantidadHijoMayor25: obtenerCantidad("hijo25"),
                    aplicaHijoMayor25: $("#aplicaHijo25").val() === "1",
                    cantidadAscendientes: obtenerCantidad("ascendiente"),
                    aplicaAscendientes: $("#aplicaAscendiente").val() === "1"
                };
                
                const detallePoliza = [];
                
                $(".fila-poliza:visible").each(function () {
                    const fila = $(this);
                    detallePoliza.push({
                        sumaAsegurada: fila.find("td:eq(0)").text().trim(),
                        montoSumaAsegurada: obtenerDecimal(fila.find("td:eq(1)").text()),
                        titular: obtenerMontoTitular(fila),
                        conyuge: obtenerMontoConyuge(fila),
                        hijo019: obtenerMontoHijo019(fila),
                        hijo2024: obtenerMontoHijo2059(fila),
                        hijoMayor25: obtenerDecimal(fila.find(".montoHijo25").text()),
                        ascendientes: obtenerDecimal(fila.find(".montoAsc").text()),
                        totalPoliza: obtenerDecimal(fila.find(".totalFila").text()),
                        descuentoQuincenal: obtenerDecimal(fila.find(".totalFilaQuincenal").text())
                    });
                });

                Swal.fire({
                    icon: 'warning',
                    title: 'Enviar Cotización SGMM',
                    html: "¿Desea enviar la cotización por correo electrónico?",
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Si, continuar',
                    cancelButtonText: 'Cancelar',
                    showCancelButton: true
                }).then( confirm => {
                    if(confirm.isConfirmed)
                    {
                        Swal.fire({
                            title: 'Ingresa tu correo electrónico',
                            input: 'email',
                            inputLabel: 'Tu dirección de correo',
                            inputPlaceholder: 'ejemplo@correo.com',
                            showCancelButton: true,
                            confirmButtonText: 'Enviar',
                            cancelButtonText: 'Cancelar',
                            inputValidator: (value) => {
                                if (!value) {
                                    return '¡Por favor, escribe tu correo electrónico!';
                                }
                                else  if (!/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(value)) {
                                    return '¡Por favor, ingresa un correo electrónico válido!';
                                }
                            }
                        }).then((result) => {
                            if (result.isConfirmed) {
                                 const command = {
                                     correo: result.value,
                                     datos: datosCotizacion,
                                     detalle: detallePoliza
                                 };
                                axios.post('/seguros/movimientos/'+modulo.Id+'/'+submodulo.Id+'/calculadora/'+opcion.Id+'?handler=EnviarCotizacionCorreo',command)
                                .then(response =>{
                                    var isSuccess = response.data;
                                    if(isSuccess != null)
                                    {
                                        Swal.fire({
                                             icon: "success",
                                             title: 'Cotización de SGMM',
                                             html: "Se envió la <b>Cotización de SGMM</b> al correo: <b>"+result.value+"</b>.",
                                             confirmButtonText: 'Cerrar'
                                        });
                                    }                                
                                })
                            }
                        });
                    }
                });
            });
        });
    </script>
}