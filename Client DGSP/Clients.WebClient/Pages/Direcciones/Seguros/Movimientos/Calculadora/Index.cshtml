@page "/seguros/movimientos/{moduloId}/{submoduloId}/calculadora/{opcionId}"
@model Clients.WebClient.Pages.Direcciones.Seguros.Movimientos.Calculadora.IndexModel
@{
    ViewData["Title"] = "Calculadora de Póliza de SGMM";
    ViewData["Titulo"] = "Calculadora de Póliza de SGMM";
    var quincenaActual = ((DateTime.Today.Month - 2) * 2)
                       + (DateTime.Today.Day <= 15 ? 1 : 2);
}

<div class="row">
    <div class="col-lg-12">
        <a class="btn btn-sm btn-danger ml-2 float-right restablecerCalculos" href="#" id="restablecerCalculos">
            <i class="fal fa-arrow-alt-circle-left"></i>
        </a>
        <a class="btn btn-sm btn-primary ml-2 float-right filtrosSgmm" href="#" id="filtrosSGMM">
            <i class="fal fa-filter"></i>
        </a>
    </div>
</div>

@if (Model.Empleado != null)
{
    var servidorPublico = "";
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header cabeceraInformacionG">
                <i class="fa-sharp fa-light fa-list-check mr-2"></i> General
            </div>
            <div class="card-body" id="cuerpoInformacionG" style="display: block">
                <div class="row col-lg-12">
                    <ul class="mb-0 fa-ul">
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-hashtag"></i></span><b>Expediente: </b> @Model.Empleado.Expediente</li>
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-calendar"></i></span><b>Servidor Público</b> @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(servidorPublico.ToLower()))</li>
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-briefcase"></i></span> <b>Puesto: </b> @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.Kardex.First().Puesto.ToLower()))</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}

@*Card para la tabla de Parentescos*@
<div class="row mt-3">
    <div class="row col-lg-12">
        <div class="col-lg-12">
