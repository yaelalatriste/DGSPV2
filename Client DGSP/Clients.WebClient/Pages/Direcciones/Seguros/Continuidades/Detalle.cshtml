            const input = document.querySelector('#inputImporte');
            
            input.addEventListener('input', (e) => {
                let valor = e.target.value;
                const terminaEnPunto = valor.endsWith('.');
                valor = valor.replace(/[^0-9.]/g, '');
                
                let partes = valor.split('.');
                let enteros = partes[0];
                let decimales = partes.slice(1).join(''); 

                // Formatear enteros
                let formateado = enteros ? new Intl.NumberFormat('es-MX').format(enteros) : '';

                if (terminaEnPunto) {
                    e.target.value = formateado + '.';
                } else if (decimales) {
                    e.target.value = formateado + '.' + decimales;
                } else {
                    e.target.value = formateado;
                }
            });

