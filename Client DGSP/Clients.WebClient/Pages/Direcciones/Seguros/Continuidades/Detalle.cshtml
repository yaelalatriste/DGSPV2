@page "/seguros/siniestros/{moduloId}/{submoduloId}/continuidades/{opcionId}/detalle/{id}"
@model Clients.WebClient.Pages.Direcciones.Seguros.Continuidades.DetalleModel
@{
    ViewData["Title"] = "Continuidades de SGMM";
    ViewData["Titulo"] = Model.Area.Nombre + " - Continuidades SGMM";
    int c = 0;
    var servidorPublico = Model.Empleado.Nombre + " " + Model.Empleado.Paterno + " " + Model.Empleado.Materno;
}

<div class="row">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header cabeceraInformacionG">
                <i class="fa-sharp fa-light fa-list-check mr-2"></i> General
            </div>
            <div class="card-body" id="cuerpoInformacionG" style="display: block">
                <div class="row col-lg-12">
                    <ul class="mb-0 fa-ul">
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-hashtag"></i></span><b>Expediente: </b> @Model.Continuidad.Expediente</li>
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-calendar"></i></span><b>Servidor Público</b> @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(servidorPublico.ToLower()))</li>
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-briefcase"></i></span> <b>Puesto: </b> @(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.Kardex.First().Puesto.ToLower()))</li>
                        <li class="medium mt-3"><span class="fa-li"><i class="fas fa-lg fa-user"></i></span> <b>Fecha de Baja: </b> @Model.Continuidad.FechaBaja</li>
                        <li class="medium mt-3"><span class="fa-li">@Html.Raw(Model.EstatusContinuidad.Icono)</span> <b style="color: @Model.EstatusContinuidad.FondoHexadecimal;">Estatus: @Model.EstatusContinuidad.Nombre</b></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-8">
        <a class="btn btn-md btn-warning float-right ml-2" href="/seguros/siniestros/@Model.Modulo.Id/@Model.Submodulo.Id/continuidades/@Model.Opcion.Id">
            <i class="fal fa-arrow-left"></i>
        </a>
        @if (Model.Oficios.Count() == 0 && Model.EstatusContinuidad.Abreviacion.Equals("EnMovimientos"))
        {
            <a class="btn btn-md btn-danger float-right ml-2 rastrearOficio" href="#">
                <i class="fal fa-search"></i>
            </a>
        }
        @if (Model.Oficios.Count() == 0 && Model.EstatusContinuidad.Id < 3)
        {
            <a class="btn btn-md btn-primary float-right ml-2 actualizarContinuidad" href="#">
                <i class="fal fa-pencil"></i>
            </a>
        }
        <a class="btn btn-md btn-dark float-right ml-2" href="#" id="registrarContacto">
            <i class="fal fa-user"></i>
        </a>
        @if (Model.EstatusContinuidad.Id > 2)
        {
            <a href="javascript:" class="btn btn-md btn-secondary float-right agregarEntregable">
                <i class="fas fa-list text-white"></i>
            </a>
        }
    </div>
</div>

<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title text-primary"><b>Continuidad</b></h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-lg-6 h5">
                        Datos de la Continuidad
                    </div>
                </div>
                <div class="row mt-2">
                    <div class="col-lg-12">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Fecha de Baja</th>
                                    <th>Puesto</th>
                                    <th>Fecha de Envío al SP</th>
                                    <th>Fecha de Limite de Pago</th>
                                    <th>Importe a Pagar</th>
                                    <th>Pagado</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>@(Model.Continuidad.FechaBaja.GetValueOrDefault().Year == 1 ? "-" : Model.Continuidad.FechaBaja.GetValueOrDefault().ToString("dd/MM/yyyy"))</td>
                                    <td>@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(Model.Kardex.First().Puesto.ToLower()))</td>
                                    <td>@(Model.Continuidad.FechaEnvioSp.GetValueOrDefault().Year == 1 ? "-" : Model.Continuidad.FechaEnvioSp.GetValueOrDefault().ToString("dd/MM/yyyy"))</td>
                                    <td>@(Model.Continuidad.FechaLimitePago.GetValueOrDefault().Year == 1 ? "-" : Model.Continuidad.FechaLimitePago.GetValueOrDefault().ToString("dd/MM/yyyy"))</td>
                                    <td>@String.Format(System.Globalization.CultureInfo.CurrentCulture, "{0:C}", Model.Continuidad.Importe)</td>
                                    <td>@(Model.Continuidad.Pagado == true ? "SI" : "NO")</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="card-footer">
                @foreach (var f in Model.FlujoContinuidad)
                {
                    if (Model.Permisos.Any(p => p.PermisoId == f.PermisoId && p.SubmoduloId == Model.Submodulo.Id))
                    {
                        @Html.Raw(f.Boton);
                    }
                }
            </div>
        </div>
    </div>
</div>

@if (Model.Oficios != null && Model.Oficios.Count() != 0)
{
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title text-secondary"><b>Oficios de Movimientos</b></h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body cuerpoMovimientos">
                    <div class="row mt-3">
                        <table class="table tblMovimientos">
                            <thead>
                                <tr>
                                    <th class="text-center">Año de Movimiento</th>
                                    <th class="text-center">Servidor Público</th>
                                    <th class="text-center">Tipo de Movimiento</th>
                                    <th class="text-center">Número de Oficio</th>
                                    <th class="text-center">Fecha de Aplicación</th>
                                    <th class="text-center">Registro de Movimiento</th>
                                    <th class="text-center">Fecha de Alta</th>
                                    <th class="text-center">Observaciones</th>
                                </tr>
                            </thead>
                            <tbody style="font-size: 14px">
                                @foreach (var of in Model.Oficios)
                                {
                                    c++;
                                    var servidorP = of.ServidorPublico.Nombre + " " + of.ServidorPublico.Paterno + " " + of.ServidorPublico.Materno;
                                    var registro = of.UsuarioRegistro.Nombre + " " + of.UsuarioRegistro.Paterno + " " + of.UsuarioRegistro.Materno;
                                    <tr>
                                        <td class="text-center">@of.AnioMovimiento</td>
                                        <td class="text-center">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(servidorP.ToLower())</td>
                                        <td class="text-center">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(of.Movimiento.fcDescMov.ToLower())</td>
                                        <td class="text-center">@of.Oficio</td>
                                        <td class="text-center">@of.FechaAplicacionMovimientoSP.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(registro.ToLower())
                                        <td class="text-center">@of.FechaAltaMovimiento.ToString("dd/MM/yyyy")</td>
                                        <td class="text-center">@(of.ObservacionMovimiento.Equals("") ? "-" : of.ObservacionMovimiento)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Contactos != null && Model.Contactos.Count() != 0)
{
    c = 0;
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title text-secondary"><b>Medios de Contacto</b></h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body cuerpoKardex">
                    <div class="row">
                        <div class="col-lg-12">
                            @if (@Model.EstatusContinuidad.Abreviacion.Equals("PendientePago"))
                            {
                                <a class="enviarCorreo float-right ml-2" href="javascript:">
                                    <i class="fa-etch fa-solid fa-comment text-success"></i>
                                </a>
                            }
                            @if (@Model.EstatusContinuidad.Abreviacion.Equals("Concluida"))
                            {
                                <a class="enviarCorreoPoliza float-right ml-2" href="javascript:">
                                    <i class="fa-light fa-clipboard-list"></i>
                                </a>
                            }
                        </div>
                    </div>
                    <table class="table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th class="text-center">Tipo</th>
                                <th class="text-center">Descripción</th>
                                <th class="text-center">Registrado el:</th>
                                <th class="text-center">Última actualización:</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody style="font-size: 14px">
                            @foreach (var k in Model.Contactos)
                            {
                                c++;
                                <tr>
                                    <td>@c</td>
                                    <td class="text-center">@k.TipoContacto.Nombre</td>
                                    <td class="text-center">@k.Descripcion</td>
                                    <td class="text-center">@k.FechaCreacion.ToString("dd/MM/yyyy hh:mm tt")</td>
                                    <td class="text-center">@(
                                        k.FechaActualizacion.GetValueOrDefault().Year != 1 ?
                                        k.FechaActualizacion.GetValueOrDefault().ToString("dd/MM/yyyy hh:mm tt") : " -"
                                    )</td>
                                    <td class="text-center">
                                        <a class="editarContacto" href="javascript:" data-tipo="@k.TipoId"
                                        data-descripcion="@k.Descripcion" data-id="@k.Id">
                                            <i class="fa-etch fa-solid fa-pencil"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.EntregablesContinuidad != null && Model.EntregablesContinuidad.Count() != 0)
{
    <div class="row">
        <div class="col-lg-12">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title text-black"><b>Entregables</b></h3>
                    <div class="card-tools">
                        <button type="button" class="btn btn-tool" data-card-widget="collapse">
                            <i class="fas fa-minus"></i>
                        </button>
                    </div>
                </div>
                <div class="card-body cuerpoKardex">
                    <div class="row col-lg-12 mt-2">
                        <div class="col-lg-12">
                            <table class="table tblKardex">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th class="text-center">Adjuntó</th>
                                        <th class="text-center">Tipo</th>
                                        <th class="text-center">Archivo</th>
                                        <th class="text-center">Fecha de Carga</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody style="font-size: 14px">
                                    @foreach (var k in Model.EntregablesContinuidad)
                                    {
                                        c++;
                                        var elaboro = @k.Usuario.NombreEmp + " " + @k.Usuario.PaternoEmp + " " + @k.Usuario.MaternoEmp;
                                        <tr>
                                            <td>@c</td>
                                            <td class="text-center">@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(elaboro.ToLower()))</td>
                                            <td class="text-center">@(k.Entregable.Nombre)</td>
                                            <td class="text-center">@k.Archivo</td>
                                            <td class="text-center">@k.FechaCreacion</td>
                                            <td class="text-center">
                                                <a class="verEntregable" href="javascript:" 
                                                data-id="@k.Id" 
                                                data-entregable="@k.Entregable.Nombre">
                                                    <i class="fas fa-eye text-success"></i>
                                                </a>
                                                @if (Model.FlujoEntregableContinuidad.Where(fe=> fe.EntregableId == k.EntregableId).Select(e => e.Editable).Count() != 0)
                                                {
                                                    <a class="editarEntregable ml-2" href="javascript:"
                                                       data-id="@k.Id"
                                                       data-archivo="@k.Archivo"
                                                       data-entregable="@k.EntregableId"
                                                       data-importe="@Model.Continuidad.Importe"
                                                       data-fechanotificacion="@Model.Continuidad.FechaEnvioSp.GetValueOrDefault().ToString("yyyy-MM-dd")"
                                                       data-fechalimite="@Model.Continuidad.FechaLimitePago.GetValueOrDefault().ToString("yyyy-MM-dd")">
                                                        <i class="fas fa-pencil text-primary"></i>
                                                    </a>
                                                    <a class="eliminarEntregable ml-2" href="javascript:"
                                                       data-id="@k.Id"
                                                       data-archivo="@k.Archivo"
                                                       data-abreviacion="@k.Entregable.Abreviacion">
                                                        <i class="fas fa-trash text-danger"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


<div class="row">
    <div class="col-lg-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title text-danger"><b>Kardex - Servidor Público</b></h3>
                <div class="card-tools">
                    <button type="button" class="btn btn-tool" data-card-widget="collapse">
                        <i class="fas fa-minus"></i>
                    </button>
                </div>
            </div>
            <div class="card-body cuerpoKardex">
                <table class="table tblKardex">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th class="text-center">Periodo de Nombremiento</th>
                            <th class="text-center">Fecha de Baja</th>
                            <th class="text-center">Clave de Puesto</th>
                            <th>Puesto</th>
                            <th>Motivo de Baja</th>
                            <th class="text-center">Rango</th>
                            <th class="text-center">Nivel</th>
                        </tr>
                    </thead>
                    <tbody style="font-size: 14px">
                        @foreach (var k in Model.Kardex)
                        {
                            c++;
                            <tr>
                                <td>@c</td>
                                <td class="text-center">
                                    @k.FechaInicioNombr.GetValueOrDefault().ToString("dd/MM/yyyy") -
                                    @(k.FechaFinNombr.GetValueOrDefault().Year > 9000 ? "Indefinido" : k.FechaFinNombr.GetValueOrDefault().ToString("dd/MM/yyyy"))
                                </td>
                                <td class="text-center">@(k.FechaBaja.GetValueOrDefault().Year == 1 ? "-" : k.FechaBaja.GetValueOrDefault().ToString("dd/MM/yyyy"))</td>
                                <td class="text-center">@k.CvePuesto</td>
                                <td>@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(k.Puesto.ToLower())</td>
                                <td class="text-center">
                                    @(k.Baja.Trim().Equals("BR") ? "Baja por Renuncia" : k.Baja.Trim().Equals("BF") ? "Baja por Fin de Nombramiento" :
                                                                    k.Baja.Trim().Equals("BCD") ? "Baja por Cambio de Denominación" :
                                                                    k.Baja.Trim().Equals("BMC") ? "Baja por Cambio de Denominación" :
                                                                    k.Baja.Trim().Equals("BCP") ? "Baja por Cambio de Plaza" : "-")
                            </td>
                            <td class="text-center">@k.Rango</td>
                            <td class="text-center">@k.Nivel</td>
                        </tr>
                                                }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@*Modal para Registrar Referencia de Pago*@
<div class="modal fade" id="modalEntregables">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <h4 class="modal-title text-white">Agregar Entregable</h4>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row col-lg-12">
                    <input type="hidden" id="inputEntregableId"/>
                    <div class="form-group col-lg-4">
                        <label for="tipoIncidencia">Entregable a registrar:</label>
                        <select class="form-control" id="inputEntregable">
                            <option value="">Seleccione una opción</option>
                            @foreach (var ti in Model.Entregables)
                            {
                                <option value="@ti.Id" data-abreviacion="@ti.Abreviacion">@ti.Nombre</option>
                            }
                        </select>
                        <div class="col-sm-12" id="error_inputEntregable">
                            <small id="dateHelp" class="text-danger">
                                Seleccione el tipo de entregable
                            </small>
                        </div>
                    </div>
                    <div class="form-group col-lg-4" id="divSuaMes">
                        <label for="tipoIncidencia">Fecha de Envió al SP:</label>
                        <input type="date" class="form-control" id="inputFechaNotificacionSP" />
                        <div class="col-sm-12" id="error_inputFechaNotificacionSP">
                            <small id="dateHelp" class="text-danger">
                                Capture la fecha de notificación al SP
                            </small>
                        </div>
                    </div>
                    <div class="form-group col-lg-4" id="divSuaMes">
                        <label for="tipoIncidencia">Fecha Límite de Pago:</label>
                        <input type="date" class="form-control" id="inputFechaLimitePago" />
                        <div class="col-sm-12" id="error_inputFechaLimitePago">
                            <small id="dateHelp" class="text-danger">
                                Capture la fecha límite de pago
                            </small>
                        </div>
                    </div>
                    <div class="form-group col-lg-4" id="divSuaMes">
                        <label for="tipoIncidencia">Importe a Pagar:</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="text" class="form-control" id="inputImporte" aria-label="Importe a pagar">
                        </div>
                        <div class="col-sm-12" id="error_inputImporte">
                            <small id="dateHelp" class="text-danger">
                                Capture el monto a pagar
                            </small>
                        </div>
                    </div>
                    <div class="form-group col-lg-6">
                        <input type="hidden" id="inputEstatusId" />
                        <label for="elegirArchivo">Seleccionar Archivo: </label>
                        <div class="custom-file">
                            <input type="file" class="custom-file-input" id="customFile" accept=".pdf,.PDF">
                            <label class="custom-file-label" for="customFile">Seleccionar Archivo</label>
                        </div>
                        <div class="col-sm-12" id="error_comprobantePDF">
                            <small id="dateHelp" class="text-danger">
                                Por favor seleccione él archivo correspondiente
                            </small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <a class="btn btn-sm btn-primary float-right" href="javascript:" id="guardarentregable">
                    Guardar
                </a>
            </div>
        </div>
        <!-- /.modal-content -->
    </div>
    <!-- /.modal-dialog -->
</div>
@*Modal para registrar la referencia de Pago*@

@*Modal para Registrar Contactos*@
<div class="modal fade" id="modalContactos">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary">
                <h4 class="modal-title text-white">Agregar/Modificar Contacto</h4>
                <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <div class="row col-lg-12">
                    <input type="hidden" id="inputContactoId" />
                    <div class="form-group col-lg-4">
                        <label for="tipoIncidencia">Tipo de Contacto:</label>
                        <select class="form-control" id="inputTipoContacto">
                            <option value="">Seleccione una opción</option>
                            @foreach (var ti in Model.TiposContacto)
                            {
                                <option value="@ti.Id" data-abreviacion="@ti.Abreviacion">@ti.Nombre</option>
                            }
                        </select>
                        <div class="col-sm-12" id="error_inputTipoContacto">
                            <small id="dateHelp" class="text-danger">
                                Seleccione el tipo de contacto
                            </small>
                        </div>
                    </div>
                    <div class="form-group col-lg-5">
                        <label for="tipoIncidencia">Descripción:</label>
                        <input type="text" class="form-control" id="inputDescripcion" />
                        <div class="col-sm-12" id="error_inputDescripcion">
                            <small id="dateHelp" class="text-danger">
