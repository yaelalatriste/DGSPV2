                        cancelButtonColor: '#d33',
                        confirmButtonText: 'Si, continuar',
                        cancelButtonText: 'Cancelar',
                        showCancelButton: true
                    }).then( confirm => {
                        if(confirm.isConfirmed)
                       {
                             Swal.fire({
                                 icon: 'info',
                                 title: 'Detalle de la Continuidad',
                                 text: 'Por favor indique alguna comentario.',
                                 showCancelButton: true,
                                 confirmButtonColor: '#3085d6',
                                 cancelButtonColor: '#d33',
                                 cancelButtonText: 'Cancelar',
                                 confirmButtonText: 'Continuar',
                                 input: 'textarea',
                                 inputPlaceholder: 'Escriba los comentarios correspondientes'
                             }).then(coments => {
                                 if (coments.value.length > 0) {
                                     Swal.fire({
                                         allowOutsideClick: false,
                                         icon: "info",
                                         title: 'Detalle de la Continuidad',
                                         html: "Procesando la Continuidad, espere por favor.",
                                    });
                                    Swal.showLoading();
                                    axios.put('/seguros/siniestros/'+modulo.id+'/'+submodulo.id+'/continuidades/'+opcion.id+'/detalle/'+continuidad.id+'?handler=EstatusContinuidad', {
                                         Id: parseInt(continuidad.id),
                                         EstatusId: parseInt(estatusId),
                                         Corregir: corregir,
                                         Pagada: pagado,
                                         Observaciones: coments.value
                                     }).then(response => {
                                         if (response.status == 200 && response.data != null) {
                                             var id = response.data.id;
                                             Swal.fire({
                                                 icon: "success",
                                                 title: 'Detalle de la Continuidad',
                                                 html: "Se procesó la <b>Continuidad</b> correctamente.",
                                                 confirmButtonText: 'Cerrar'
                                             }).then(function () {
                                                 Swal.fire({
                                                     allowOutsideClick: false,
                                                     icon: "info",
                                                     title: 'Detalle de la Continuidad',
                                                     html: "Actualizando, espere por favor."
                                                 });
                                                 Swal.showLoading();
                                                 window.location.reload();
                                             });
                                        }
                                        else
                                        {
                                            Swal.fire({
                                                allowOutsideClick: false,
                                                icon: "error",
                                                title: 'Detalle de la Continuidad',
                                                html: "<p style='text-align: justify'>No se puede cambiar el estatus de la continuidad, por favor verifique que ya registro la fecha de baja y adjuntó los entregables correspondientes o bien, contacte al administrador del sistema.</p>"
                                            });
                                        }
                                    });
                                 }
                             });
                          }
                    });
            });

            $(".verEntregable").click(function () {
                let url = '/seguros/siniestros/' + modulo.id + '/' + submodulo.id + '/continuidades/' + opcion.id + '/detalle/' + continuidad.id + '?entregableId=' +$(this).data('id')+ '&handler=VisualizarEntregable';
                let data = '<iframe src="' + url + '" style="width:100%; height:100%; border:none;"></iframe>';
                $("#titleVerEntregables").text($(this).data('entregable'));
                $('#objectPdf').html(data);
                $("#modalVerEntregables").modal("show");
            });
        });
    </script>
}